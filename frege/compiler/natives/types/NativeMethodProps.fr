module Compiler.natives.types.NativeMethodProps where

import Compiler.types.QNames(QName())
import Compiler.types.Positions(Position())

{--
Gathers all data for the GenNative pass to generate a native declaration for a method.
-}
data NativeMethodProps = NativeMethodProps { nativeName :: String, parentName :: QName, pos :: Position, pur :: Bool }
