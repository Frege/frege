module tests.qc.gennative.JTypeQualificationSpec where

import Compiler.classes.HasClassLoader(HasClassLoader)
import Compiler.common.CompilerOptions(standardGlobal)
import Compiler.common.SymbolTable(enter)
import Compiler.types.Global(Global, HasGlobalState(getST))
import Compiler.types.Packs(Pack)
import Compiler.types.Positions(Position)
import Compiler.types.QNames(VName, TName)
import Compiler.natives.types.JTypes(JMethodT, JVarT, JTypeT, NativeName, QualifiedName, WildcardBounds(Upper, Lower), MemberType(InstanceMethod), Env(Env))
import Compiler.natives.conversion.JTypeQualification(qualify, qualifySingleNative, nativeSym, nativeExists)
import Control.monad.State(State(run))
import Test.QuickCheck
import Data.TreeMap(contains, TreeMap(), singleton, keys)
import Compiler.types.Packs(pPreludeBase)
import frege.data.HashMap(HashMap)

import tests.qc.gennative.JTypesSpec()

p_ShouldQualifySpecialTypes :: Property
p_ShouldQualifySpecialTypes = once $ let
    tpls = [("void", "()"), ("java.lang.String", "String"), ("java.lang.Object", "Object")]
    g = compileGlobal
    ntvs = map ((flip NativeName []) . fst) tpls
    (qs, _) = run (mapM (qualifySingleNative emptyJMethod) ntvs) g
  in
      (map (\q -> q.name.base) qs) ==? (map snd tpls)

p_ShouldQualifyNonExistingSingleNative :: Property
p_ShouldQualifyNonExistingSingleNative = once $ do
  pack <- fmap Pack.new $ arbitrary
  let g = compileGlobal.{ sub <- (_.{ thisPack = pack}), javaEnv = TreeMap.empty }
  let ntv = NativeName "simple.Name" []
  let (q, g') = (run ((qualifySingleNative emptyJMethod) ntv) g)
  let env = g'.javaEnv.lookupS ntv.fqn
  pure $
    q.name ==? (TName pack ntv.fqn) .&&.
    fmap fst env ==? Just ["java.lang.Object"]

p_shouldFindExistingNative :: Property
p_shouldFindExistingNative = once $ do
  let pack  = Pack.new "example"
  let ntv   = NativeName "simple.Name" []
  let qName = TName pack ntv.fqn
  -- prepare global
  let g'      = compileGlobal.{
                    javaEnv  <- (_.insert ntv.fqn ([], [qName]) )
                  , packages <- (_.insert pack TreeMap.empty)
                  }
  -- create a symbol & look for it
  let mkSymAction = mkSym ntv pack emptyJMethod
  let action  =  mkSymAction >> qualifySingleNative emptyJMethod ntv
  let (fqn, _)  = (run action g')
  (fqn.name ==? qName) .&&. (fqn.env ==? (Env stateIdx))
  where
    mkSym ntv pack jMethod = 
      fmap addIdx (nativeSym Position.null (ntv.fqn, []) pack jMethod) >>= enter
    addIdx sym = sym.{ stateIdx = Just stateIdx }
    stateIdx = (TName pPreludeBase "TestWorld")

p_ShouldQualifyJMethod :: Property
p_ShouldQualifyJMethod = property $ \(jMethod' :: (JMethodT NativeName)) -> let 
    jMethod = jMethod'.{exs <- (filter keepJTypes)}
    names = toList jMethod
    pack  = Pack.new "package"
    -- we qualify missing symbols in the current package
    startingGlobal = compileGlobal.{
        sub      <- (_.{thisPack = pack})
      , packages <- (_.insert pack TreeMap.empty)
      }
    -- If we qualify the method ...
    (_ ,g) = run (qualify jMethod) startingGlobal
    
    -- ... We should find all symbols as qualified
    (r, _1) = run (mapM nativeExists (map NativeName.fqn names)) g
  in allQualified r where
    allQualified []            = True
    allQualified ((Just _):as) = allQualified as
    allQualified _             = False
    keepJTypes JType{} = True
    keepJTypes _ = False

p_ShouldQualifyExceptionsAsPure :: Property
p_ShouldQualifyExceptionsAsPure = property $ \(jMethod' :: (JMethodT NativeName)) -> 
  length jMethod'.exs > 0 ==>
  let 
    jMethod    = jMethod'.{exs <- (filter keepJTypes)}
    exceptions = map JTypeT.typeRef jMethod.exs
    pack  = Pack.new "package"
    -- we qualify missing symbols in the current package
    startingGlobal = compileGlobal.{
        sub      <- (_.{thisPack = pack})
      , packages <- (_.insert pack TreeMap.empty)
      }
    -- If we qualify the method ...
    (_ ,g) = run (qualify jMethod) startingGlobal
    
    -- ... All exceptions should be qualified as pure types
    (r, _1) = run (mapM nativeExists (map NativeName.fqn exceptions)) g
    exceptions' = filter (\e -> e.name.base `elem` (map NativeName.fqn exceptions)) (catMaybes r)
  in allPure exceptions' where
    allPure []            = True
    allPure (a:as) = a.env.isPure && allPure as
    allPure _             = False
    keepJTypes JType{} = True
    keepJTypes _ = False


-- Generators, we return each generated native name alongside so that we can
-- assert on them

emptyJMethod = JMethod [] (JType (NativeName "test" []) []) [] HashMap.empty InstanceMethod

alphaChars :: Gen Char
alphaChars = elements ['a'..'z']

alphaString :: Gen String
alphaString = do
  n    <- choose (3,10)
  str  <- vectorOf n alphaChars
  pure $ packed str

fqn :: Gen String
fqn = do
  n    <- choose (1,5)
  path <- vectorOf n alphaString
  pure $ joined "." path


instance Arbitrary NativeName where
  arbitrary = do
    params <- choose (0,1) >>= flip vectorOf arbitrary -- using more params makes the tests too slow
    f      <- fqn
    pure (NativeName f params)


{--
This is a dummy instance for testing purposes only.
-}
instance HasClassLoader (State Global) where
  loadClass name = 
    -- we always return our example class here
    pure $ Right exampleClass
  findInterfaces clazz = pure []
  {--
  We simply return java.lang.Object as super type
  -}
  -- Break endless recursion
  findSuperclass clazz | clazz.getName == "java.lang.Object" = pure Nothing
  findSuperclass _ = 
    pure $ Just objectClass
  forName name _ = loadClass name

pure native objectClass "java.lang.Object.class" :: Class a
pure native exampleClass "tests.qc.gennative.ExampleClass.class" :: Class a

{-- 
nowarn: performUnsafe

We need access to the Global object during tests, which we can only obtain in
`IO`, because it relies on the Classloader. For simplicity we cheat here to
obtain a "pure" Global object.
-}
compileGlobal :: Global
compileGlobal = withPack $ IO.performUnsafe standardGlobal
  where
    pack = Pack.new "example"
    withPack :: Global -> Global
    withPack g = g.{
      sub <- (\sub -> sub.{thisPack = pack})
    , packages <- (_.insert pack TreeMap.empty)
    }
