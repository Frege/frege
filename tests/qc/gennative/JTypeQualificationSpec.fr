module tests.qc.gennative.JTypeQualificationSpec where

import Compiler.common.CompilerOptions(standardGlobal)
import Compiler.common.SymbolTable(enter)
import Compiler.types.Global(Global)
import Compiler.types.Packs(Pack)
import Compiler.types.Positions(Position)
import Compiler.types.QNames(VName, TName)
import Compiler.natives.types.JTypes(JMethodT, JVarT, JTypeT, NativeName, QualifiedName, WildcardBounds(Upper, Lower), MemberType(InstanceMethod))
import Compiler.natives.conversion.JTypeQualification(qualify, qualifySingleNative, nativeSym, nativeExists)
import Control.monad.State(State(run))
import Test.QuickCheck
import Data.TreeMap(contains, TreeMap(), singleton, keys)
import Data.HashMap(HashMap())

p_ShouldQualifySpecialTypes :: Property
p_ShouldQualifySpecialTypes = once $ let
    tpls = [("void", "()"), ("java.lang.String", "String"), ("java.lang.Object", "Object")]
    g = compileGlobal
    ntvs = map ((flip NativeName []) . fst) tpls
    (qs, _) = run (mapM qualifySingleNative ntvs) g
  in
      (map (\q -> q.name.base) qs) ==? (map snd tpls)

p_ShouldQualifyNonExistingSingleNative :: Property
p_ShouldQualifyNonExistingSingleNative = once $ do
  pack <- fmap Pack.new $ arbitrary
  let g = compileGlobal.{ sub <- (_.{ thisPack = pack }) }
  let ntv = NativeName "simple.Name" []
  let (q, g') = (run (qualifySingleNative ntv) g)
  pure $
    q.name == (VName pack ntv.fqn) &&
    contains g'.javaEnv ntv.fqn

p_shouldFindExistingNative :: Property
p_shouldFindExistingNative = once $ do
  let pack  = Pack.new "example"
  let ntv   = NativeName "simple.Name" []
  let qName = VName pack ntv.fqn
  -- prepare global
  let g'      = compileGlobal.{
                    javaEnv  <- (_.insert ntv.fqn ([], [qName]) )
                  , packages <- (_.insert pack TreeMap.empty)
                  }
  -- look for symbol
  let action  = nativeSym Position.null (ntv.fqn, []) pack >>= enter >> nativeExists ntv.fqn
  let (r, _)  = (run action g')
  case r of
    Nothing    -> False
    (Just fqn) -> fqn.name == qName

p_ShouldQualifyJMethod :: Property
p_ShouldQualifyJMethod = property $ do
  (names, jMethod) <- mkJMethod
  let pack           = Pack.new "package"
  -- we qualify missing symbols in the current package
  let startingGlobal = compileGlobal.{
      sub      <- (_.{thisPack = pack})
    , packages <- (_.insert pack TreeMap.empty)
    }
  -- If we qualify the method ...
  let (_ ,g) = (qualify jMethod).run startingGlobal
  
  -- ... We should find all symbols as qualified
  let (r, _) = (mapM nativeExists (map NativeName.fqn names)).run g
  pure $ allQualified r where
    allQualified []            = True
    allQualified ((Just _):as) = allQualified as
    allQualified _             = False


-- Generators, we return each generated native name alongside so that we can
-- assert on them

alphaChars :: Gen Char
alphaChars = elements ['a'..'z']

alphaString :: Gen String
alphaString = do
  n    <- choose (3,10)
  str  <- vectorOf n alphaChars
  pure $ packed str

fqn :: Gen String
fqn = do
  n    <- choose (1,5)
  path <- vectorOf n alphaString
  pure $ joined "." path

mkNativeName :: Gen ([NativeName], NativeName)
mkNativeName = do
    f      <- fqn
    (paramNames, params) <- unzip <$> (choose (0,1) >>= flip vectorOf mkJVar)
    pure (concat paramNames, NativeName f params)

mkJType :: Gen ([NativeName], JTypeT NativeName)
mkJType = 
    oneof [jtype, jWildcard, jVarRef]
      where
        jtype = do
          (paramNames, name) <- mkNativeName
          (names, args) <- unzip <$> (choose (0,1) >>= flip vectorOf mkJType)
          pure $ (name : concat names ++ paramNames, JType name args)
        jWildcard = do
          (names, args) <- unzip <$> (choose (0,1) >>= flip vectorOf mkJType)
          bounds <- oneof [pure $ Upper args, pure $ Lower args]
          pure (concat names, JWildcard bounds)
        jVarRef = do 
          name <- arbitrary
          pure ([], JVarRef name)
 
mkJVar :: Gen ([NativeName], JVarT NativeName)
mkJVar = do
        name   <- arbitrary
        (names, bounds) <- unzip <$> (choose (0,1) >>= flip vectorOf mkJType)
        pure (concat names, JVar name bounds)

mkJMethod :: Gen ([NativeName], JMethodT NativeName)
mkJMethod = do
  (pNames, params)    <- unzip <$> (choose (0,2) >>= flip vectorOf mkJType)
  (rNames, returnVal) <- mkJType
  (eNames, exs)       <- unzip <$> (choose (0,2) >>= flip vectorOf mkJType)
  pure (rNames ++ concat (pNames ++ eNames), JMethod params returnVal exs HashMap.empty InstanceMethod)

{-- 
nowarn: performUnsafe

We need access to the Global object during tests, which we can only obtain in
`IO`, because it relies on the Classloader. For simplicity we cheat here to
obtain a "pure" Global object.
-}
compileGlobal :: Global
compileGlobal = IO.performUnsafe standardGlobal

