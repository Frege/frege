module tests.qc.gennative.JTypeConversionSpec where

import Test.QuickCheck
import Compiler.natives.conversion.JTypeConversion(classToJType, toJType)
import Compiler.natives.types.JTypes(JVarRef, JTypeT(JType), NativeName(Array))
import Java.lang.Reflect(Method, getMethods)
import tests.qc.gennative.TypeExtractionSpec(withExampleClass)

p_ShouldConvertClassWithFBoundToJType :: Property
p_ShouldConvertClassWithFBoundToJType = withExampleClass $ \clazz ->
  once $
    let 
      jType          = classToJType clazz
      typeParams     = jType.typeRef.typeParams
      typeParamBound = head (head typeParams).bounds
      typeArgs       = jType.typeArgs
    in conjoin [
        jType.typeRef.fqn              ==? "tests.qc.gennative.ExampleClass"
      , length typeArgs                ==? length typeParams
      , (head typeParams).name         ==? "T"
      -- type bounds
      , typeParamBound.typeRef.fqn     ==? "java.lang.Comparable"
      , length typeParamBound.typeArgs ==? length typeParamBound.typeRef.typeParams
      , head typeParamBound.typeArgs   ==? JVarRef "T"
      ]

p_ShouldConvertArrayToJType :: Property
p_ShouldConvertArrayToJType = withExampleMethod "getIntArray" $ \method ->
  once $
    let 
      jType     = toJType method.getGenericReturnType
      component = jType.typeArgs.head.typeRef.fqn
    in conjoin [
        jType.typeRef ==? Array 
      , component     ==? "int"
      ]

p_ShouldConvertWildcardTypeToJType :: Property
p_ShouldConvertWildcardTypeToJType = withExampleMethod "getWildcardList" $ \method ->
  once $
    let 
      jType          = toJType method.getGenericReturnType
      typeParams     = jType.typeRef.typeParams
      typeArgs       = jType.typeArgs
      wildcardBounds = typeArgs.head.bounds.bounds
    in conjoin [
        jType.typeRef.fqn                 ==? "java.util.List"
      , length typeArgs                   ==? length typeParams
      , (head typeParams).name            ==? "E"
      , (head wildcardBounds).typeRef.fqn ==? "java.lang.Number"
      ]
  
p_ShouldConvertRawTypeToJType :: Property
p_ShouldConvertRawTypeToJType = withExampleMethod "getRawList" $ \method ->
  once $
    let 
      jType      = toJType method.getGenericReturnType
      typeParams = jType.typeRef.typeParams
      typeArgs   = jType.typeArgs
    in conjoin [
        jType.typeRef.fqn           ==? "java.util.List"
      , length typeArgs             ==? length typeParams
      , (head typeParams).name      ==? "E"
      , (head typeArgs).typeRef.fqn ==? "java.lang.Object"
      ]

p_ShouldConvertTypeVariableToJType :: Property
p_ShouldConvertTypeVariableToJType = withExampleMethod "setValue" $ \method ->
  once $
    let 
      jType = toJType $ head method.getGenericParameterTypes.toList
    in 
      jType.ref ==? "T"

p_ShouldConvertParameterizedTypeToJType :: Property
p_ShouldConvertParameterizedTypeToJType = withExampleMethod "processParameterizedType" $ \method ->
  once $
    let 
      jType          = toJType $ head method.getGenericParameterTypes.toList
      typeParams     = jType.typeRef.typeParams
      typeArgs       = jType.typeArgs
    in conjoin [
        jType.typeRef.fqn ==? "java.util.List"
      , length typeArgs   ==? length typeParams
      -- bounds are not part of the jtype but of the jmethod which defines E
      , typeArgs.head.ref ==? "E"
      ]

p_ShouldConvertPrimitiveTypesToJType :: Property
p_ShouldConvertPrimitiveTypesToJType = withExampleMethod "primitive" $ \method ->
  once $
    let 
      jType = toJType method.getGenericReturnType
    in conjoin [
        length jType.typeArgs           ==? 0
      , length jType.typeRef.typeParams ==? 0
      , jType.typeRef.fqn               ==? "int"
      ]

p_ShouldConvertGenericArrayTypeToJType :: Property
p_ShouldConvertGenericArrayTypeToJType = withExampleMethod "getArrayOfLists" $ \method ->
  once $
    let 
      jType          = toJType method.getGenericReturnType
      -- component type
      componentArgs  = jType.typeArgs.head
      -- component type is List, lets get its type params/args
      compTypeArgs   = componentArgs.typeArgs
      compTypeParams = componentArgs.typeRef.typeParams
    in conjoin [
        jType.typeRef                 ==? Array 
      , componentArgs.typeRef.fqn     ==? "java.util.List"
      , compTypeParams.head.name      ==? "E"
      , compTypeParams.length         ==? compTypeArgs.length
      , compTypeArgs.head.typeRef.fqn ==? "java.lang.String"
      ]

--- Gives us access to a method in ExampleClass
withExampleMethod :: Testable t =>  String -> (Method -> t) -> Property
withExampleMethod methodName test = 
  withExampleClass $ \clazz -> do
    let method = head $ filter (\m -> m.getName == methodName) (getMethods clazz).toList
    test method
