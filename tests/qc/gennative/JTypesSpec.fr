module tests.qc.gennative.JTypesSpec where

import Test.QuickCheck

import Compiler.natives.types.JTypes
import Data.wrapper.Identity(Identity())
import Data.Traversable(traverse)
import Data.Compose(Compose)
import Compiler.types.Types(TauT(TCon))
import Data.HashMap(HashMap(), fromList)
import Compiler.types.Positions(Position)

import Compiler.types.QNames(QName(TName))
import Compiler.types.Packs(pPreludeBase)

stIdx   = TName pPreludeBase "TestWorld"
testWorld = TCon Position.null stIdx

allEnvs = [Pure, EnvS, Env stIdx, EnvIO]

instance Arbitrary Env where
  arbitrary =
     oneof $ map pure allEnvs
  shrink Pure = []
  shrink EnvS = [Pure]
  shrink (EnvIO) = [EnvS, Pure]
  shrink (Env _) = [EnvIO]

mkQualifiedNameInEnv :: [Env] -> Gen (Env, QualifiedName)
mkQualifiedNameInEnv allEnvs = do
   name <- arbitrary `suchThat` (not . null)
   env  <- oneof (map pure allEnvs)
   let qname = TName pPreludeBase name
   pure (env, QualifiedName qname env)

mkJTypeInEnv :: [Env] -> Gen ([Env], QualifiedJType)
mkJTypeInEnv allEnvs = 
    oneof [jtype, jWildcard, jVarRef]
      where
        jtype = do
          (env, name) <- mkQualifiedNameInEnv allEnvs
          (envs, args) <- unzip <$> (choose (0,2) >>= flip vectorOf (mkJTypeInEnv allEnvs))
          pure $ (env : concat envs, JType name args)
        jWildcard = do
          (envs, args) <- unzip <$> (choose (0,2) >>= flip vectorOf (mkJTypeInEnv allEnvs))
          bounds <- oneof [pure $ Upper args, pure $ Lower args]
          pure (concat envs, JWildcard bounds)
        jVarRef = do 
          name <- arbitrary `suchThat` (not . null)
          pure ([], JVarRef name)

mkJMethodInEnv :: [Env] -> Gen ([Env], QualifiedJMethod)
mkJMethodInEnv allEnvs = do
  (envs, args)   <- unzip <$> (choose (0,5) >>= flip vectorOf (mkJTypeInEnv allEnvs))
  (exsEnvs, exs) <- unzip <$> (choose (0,2) >>= flip vectorOf (mkJTypeInEnv allEnvs))
  (e, returnVal) <- (mkJTypeInEnv allEnvs)

  (varEnvs, vars) <- bindVars (returnVal : (args ++ exs))
  pure (e ++ varEnvs ++ (join envs) ++ (join exsEnvs), JMethod args returnVal exs vars InstanceMethod)
    where
      bindVars :: [QualifiedJType] -> Gen ([Env], HashMap String QualifiedJVar)
      bindVars types =  do
        vars <- mapM createJVar (filterJVarRefNames types)
        pure $ (join (map fst vars), fromList (map snd vars))
          where
            filterJVarRefNames :: [QualifiedJType] -> [String]
            filterJVarRefNames types = mapMaybe (\a -> case a of
                      (JVarRef n) -> Just n
                      _           -> Nothing) types
            createJVar :: String -> Gen ([Env], (String, QualifiedJVar))
            createJVar n = do 
              (es, j) <- (mkJVarInEnv allEnvs n)
              pure (es, (n, j))
 
mkJVarInEnv :: [Env] -> String -> Gen ([Env], QualifiedJVar)
mkJVarInEnv allEnvs name = do
        (envs, bounds) <- unzip <$> (choose (0,2) >>= flip vectorOf (mkJTypeInEnv allEnvs))
        pure (concat envs, JVar name bounds)

mkJVar    = mkJVarInEnv allEnvs
mkJType   = mkJTypeInEnv allEnvs
mkJMethod = mkJMethodInEnv allEnvs

p_ShouldReturnAllEnvsOfJVar :: Property
p_ShouldReturnAllEnvsOfJVar = property $ do
    (envs, jvar) <- arbitrary >>= mkJVar
    pure $
      and $ map (flip elem jvar.envs) envs 

p_ShouldReturnAllEnvsOfJType :: Property
p_ShouldReturnAllEnvsOfJType = property $ do
    (envs, jtype) <- mkJType
    pure $
      and $ map (flip elem jtype.envs) envs 

p_ShouldFindEnvOfJVar :: Property
p_ShouldFindEnvOfJVar = property $ do
    (env, jvar) <- arbitrary >>= mkJVar
    length env > 0 ==>
      JVarT.hasEnv (head env) jvar

p_ShouldFindEnvOfJType :: Property
p_ShouldFindEnvOfJType = property $ do
    (env, jtype) <- mkJType
    length env > 0 ==>
      JTypeT.hasEnv (head env) jtype

inferEnv :: [Env] -> Maybe Env
inferEnv envs 
  | EnvIO `elem` envs = Just EnvIO
  | (Env stIdx) `elem` envs = Just (Env stIdx)
  | EnvS  `elem` envs = Just EnvS
  | otherwise = Nothing

-- Functor laws JVar (https://wiki.haskell.org/index.php?title=Functor)

p_JVarShouldNotChangeWhenMappingId :: Property
p_JVarShouldNotChangeWhenMappingId = property $ do
  (_, jvar) <- arbitrary >>= mkJVar
  pure $ fmap id jvar == jvar
  
p_JVarShouldPreserveCompositionOfMorphisms :: Property
p_JVarShouldPreserveCompositionOfMorphisms = property $ do
  (_, jvar) <- arbitrary >>= mkJVar
  pure $ fmap (f . g) jvar ==  (fmap f . fmap g) jvar
    where 
      f :: QName -> String
      f n = n.base
      g :: QualifiedName -> QName
      g q = q.name

-- Functor laws JType (https://wiki.haskell.org/index.php?title=Functor)

p_JTypeShouldNotChangeWhenMappingId :: Property
p_JTypeShouldNotChangeWhenMappingId = property $ do
  (_, jtype) <- mkJType
  pure $ fmap id jtype == jtype
  
p_JTypeShouldPreserveCompositionOfMorphisms :: Property
p_JTypeShouldPreserveCompositionOfMorphisms = property $ do
  (_, jtype) <- mkJType
  pure $ fmap (f . g) jtype ==  (fmap f . fmap g) jtype
    where 
      f :: QName -> String
      f n = n.base
      g :: QualifiedName -> QName
      g q = q.name

-- Traversable laws JType (https://hackage-content.haskell.org/package/base-4.22.0.0/docs/Data-Traversable.html#g:20)

p_JTypeShouldHoldNaturalityLawWhenTraversing :: Property
p_JTypeShouldHoldNaturalityLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure ((t . (traverse f)) jtype == (traverse (t . f)) jtype)
    where 
      f :: QualifiedName -> Identity QName
      f n = pure n.name
      t :: Identity a -> Identity a
      t a = id a

p_JTypeShouldHoldIdentityLawWhenTraversing :: Property
p_JTypeShouldHoldIdentityLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure $ (traverse identity) jtype == identity jtype
    where 
      identity :: a -> Identity a
      identity a = pure a
  
p_JTypeShouldHoldCompositionLawWhenTraversing :: Property
p_JTypeShouldHoldCompositionLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure $ (lhs jtype).run == (rhs jtype).run
    where 
      f :: QualifiedName -> Identity QName
      f n = pure $ n.name
      g :: QName -> Identity String
      g q = pure q.base
      lhs :: QualifiedJType -> Compose Identity Identity (JTypeT String)
      lhs jtype = (traverse (Compose . fmap g . f)) jtype
      rhs :: QualifiedJType -> Compose Identity Identity (JTypeT String)
      rhs jtype = (Compose . fmap (traverse g) . traverse f) jtype

-- Traversable laws JVar (https://hackage-content.haskell.org/package/base-4.22.0.0/docs/Data-Traversable.html#g:20)

p_JVarShouldHoldNaturalityLawWhenTraversing :: Property
p_JVarShouldHoldNaturalityLawWhenTraversing = property $ do
  (_, jvar) <- arbitrary >>= mkJVar
  pure ((t . (traverse f)) jvar == (traverse (t . f)) jvar)
    where 
      f :: QualifiedName -> Identity QName
      f n = pure n.name
      t :: Identity a -> Identity a
      t a = id a

p_JVarShouldHoldIdentityLawWhenTraversing :: Property
p_JVarShouldHoldIdentityLawWhenTraversing = property $ do
  (_, jvar) <- arbitrary >>= mkJVar
  pure $ (traverse identity) jvar == identity jvar
    where 
      identity :: a -> Identity a
      identity a = pure a
  
p_JVarShouldHoldCompositionLawWhenTraversing :: Property
p_JVarShouldHoldCompositionLawWhenTraversing = property $ do
  (_, jvar) <- arbitrary >>= mkJVar
  pure $ (lhs jvar).run == (rhs jvar).run
    where 
      f :: QualifiedName -> Identity QName
      f n = pure $ n.name
      g :: QName -> Identity String
      g q = pure q.base
      lhs :: QualifiedJVar -> Compose Identity Identity (JVarT String)
      lhs jvar = (traverse (Compose . fmap g . f)) jvar
      rhs :: QualifiedJVar -> Compose Identity Identity (JVarT String)
      rhs jvar = (Compose . fmap (traverse g) . traverse f) jvar
