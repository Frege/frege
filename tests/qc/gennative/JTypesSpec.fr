module tests.qc.gennative.JTypesSpec where

import Test.QuickCheck

import Compiler.natives.types.JTypes
import Data.wrapper.Identity(Identity())
import Data.Traversable(traverse)
import Data.Compose(Compose)

import Compiler.types.QNames(QName(TName))
import Compiler.types.Packs(pPreludeBase)
-- some generally used stuff
instance Arbitrary (QualifiedName)

mkQualifiedName :: Gen (Env, QualifiedName)
mkQualifiedName = do
   name <- arbitrary
   env  <- arbitrary
   let qname = TName pPreludeBase name
   pure (env, QualifiedName qname env)

mkJType :: Gen ([Env], JTypeT QualifiedName)
mkJType = 
    oneof [jtype, jWildcard, jVarRef]
      where
        jtype = do
          (env, name) <- mkQualifiedName
          (envs, args) <- unzip <$> (choose (0,2) >>= flip vectorOf mkJType)
          pure $ (env : concat envs, JType name args)
        jWildcard = do
          (envs, args) <- unzip <$> (choose (0,2) >>= flip vectorOf mkJType)
          bounds <- oneof [pure $ Upper args, pure $ Lower args]
          pure (concat envs, JWildcard bounds)
        jVarRef = do 
          name <- arbitrary
          pure ([], JVarRef name)
 
mkJVar :: Gen ([Env], JVarT QualifiedName)
mkJVar = do
        name <- arbitrary
        (envs, bounds) <- unzip <$> (choose (0,2) >>= flip vectorOf mkJType)
        pure (concat envs, JVar name bounds)

instance Arbitrary Env where
  arbitrary =
     oneof $ map pure [Pure, EnvS, EnvIO]
  shrink Pure = []
  shrink EnvS = [Pure]
  shrink EnvIO = [EnvS, Pure]

p_ShouldCorrectlyInferEnvOfJVar :: Property
p_ShouldCorrectlyInferEnvOfJVar = property $ do
    (env, jvar) <- mkJVar
    length env > 0 ==>
      JVarT.hasEnv (head env) jvar

p_ShouldCorrectlyInferEnvOfJType :: Property
p_ShouldCorrectlyInferEnvOfJType = property $ do
    (env, jtype) <- mkJType
    length env > 0 ==>
      JTypeT.hasEnv (head env) jtype

-- Functor laws JVar (https://wiki.haskell.org/index.php?title=Functor)

p_JVarShouldNotChangeWhenMappingId :: Property
p_JVarShouldNotChangeWhenMappingId = property $ do
  (_, jvar) <- mkJVar
  pure $ fmap id jvar == jvar
  
p_JVarShouldPreserveCompositionOfMorphisms :: Property
p_JVarShouldPreserveCompositionOfMorphisms = property $ do
  (_, jvar) <- mkJVar
  pure $ fmap (f . g) jvar ==  (fmap f . fmap g) jvar
    where 
      f :: QName -> String
      f n = n.base
      g :: QualifiedName -> QName
      g q = q.name

-- Functor laws JType (https://wiki.haskell.org/index.php?title=Functor)

p_JTypeShouldNotChangeWhenMappingId :: Property
p_JTypeShouldNotChangeWhenMappingId = property $ do
  (_, jtype) <- mkJType
  pure $ fmap id jtype == jtype
  
p_JTypeShouldPreserveCompositionOfMorphisms :: Property
p_JTypeShouldPreserveCompositionOfMorphisms = property $ do
  (_, jtype) <- mkJType
  pure $ fmap (f . g) jtype ==  (fmap f . fmap g) jtype
    where 
      f :: QName -> String
      f n = n.base
      g :: QualifiedName -> QName
      g q = q.name

-- Traversable laws JType (https://hackage-content.haskell.org/package/base-4.22.0.0/docs/Data-Traversable.html#g:20)

p_JTypeShouldHoldNaturalityLawWhenTraversing :: Property
p_JTypeShouldHoldNaturalityLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure ((t . (traverse f)) jtype == (traverse (t . f)) jtype)
    where 
      f :: QualifiedName -> Identity QName
      f n = pure n.name
      t :: Identity a -> Identity a
      t a = id a

p_JTypeShouldHoldIdentityLawWhenTraversing :: Property
p_JTypeShouldHoldIdentityLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure $ (traverse identity) jtype == identity jtype
    where 
      identity :: a -> Identity a
      identity a = pure a
  
p_JTypeShouldHoldCompositionLawWhenTraversing :: Property
p_JTypeShouldHoldCompositionLawWhenTraversing = property $ do
  (_, jtype) <- mkJType
  pure $ (lhs jtype).run == (rhs jtype).run
    where 
      f :: QualifiedName -> Identity QName
      f n = pure $ n.name
      g :: QName -> Identity String
      g q = pure q.base
      lhs :: JType -> Compose Identity Identity (JTypeT String)
      lhs jtype = (traverse (Compose . fmap g . f)) jtype
      rhs :: JType -> Compose Identity Identity (JTypeT String)
      rhs jtype = (Compose . fmap (traverse g) . traverse f) jtype

-- Traversable laws JVar (https://hackage-content.haskell.org/package/base-4.22.0.0/docs/Data-Traversable.html#g:20)

p_JVarShouldHoldNaturalityLawWhenTraversing :: Property
p_JVarShouldHoldNaturalityLawWhenTraversing = property $ do
  (_, jvar) <- mkJVar
  pure ((t . (traverse f)) jvar == (traverse (t . f)) jvar)
    where 
      f :: QualifiedName -> Identity QName
      f n = pure n.name
      t :: Identity a -> Identity a
      t a = id a

p_JVarShouldHoldIdentityLawWhenTraversing :: Property
p_JVarShouldHoldIdentityLawWhenTraversing = property $ do
  (_, jvar) <- mkJVar
  pure $ (traverse identity) jvar == identity jvar
    where 
      identity :: a -> Identity a
      identity a = pure a
  
p_JVarShouldHoldCompositionLawWhenTraversing :: Property
p_JVarShouldHoldCompositionLawWhenTraversing = property $ do
  (_, jvar) <- mkJVar
  pure $ (lhs jvar).run == (rhs jvar).run
    where 
      f :: QualifiedName -> Identity QName
      f n = pure $ n.name
      g :: QName -> Identity String
      g q = pure q.base
      lhs :: JVar -> Compose Identity Identity (JVarT String)
      lhs jvar = (traverse (Compose . fmap g . f)) jvar
      rhs :: JVar -> Compose Identity Identity (JVarT String)
      rhs jvar = (Compose . fmap (traverse g) . traverse f) jvar
