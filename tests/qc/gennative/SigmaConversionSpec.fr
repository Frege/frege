module tests.qc.gennative.SigmaConversionSpec where

import Test.QuickCheck

import Compiler.types.QNames(QName(VName))
import Compiler.types.Positions(Position)
import Compiler.types.QNames(QName(TName))
import Compiler.types.Types(
    Context
  , ContextT()
  , Kind
  , KindT(KGen, KType)
  , Rho
  , RhoT(RhoTau, RhoFun)
  , Sigma
  , SigmaT(ForAll)
  , Tau
  , TauT(TApp, TCon, TVar)
  , walkRho
  , unST
  , MetaTvT
  )
import Compiler.types.Packs(
    Pack()
  , pPreludeBase
  , pPreludeIO
  )
import Compiler.natives.types.JTypes(
    Env(Pure, EnvS, Env)
  , JMethodT(JMethod)
  , JMethod
  , JTypeT(JType, JVarRef, JWildcard)
  , JVarT(JVar)
  , QualifiedName(QualifiedName)
  , WildcardBounds(Upper, Lower)
  , MemberType(InstanceMethod)
  , QualifiedJMethod
  , ResolvedName
  )
import Compiler.natives.conversion.SigmaConversion(toSigma)
import Data.HashMap(HashMap)

import tests.qc.gennative.JTypesSpec(stIdx, testWorld)

-- some generally used stuff
pos     = Position.null
pack    = Pack.new "SigmaConversionSpec"
unit    = TName pPreludeBase "()"
unitRho = RhoTau [] (tcon unit)
s       = TVar Position.null KType "s"
mutS    = mut s
mut s a = TApp (TApp (TCon pos mut') s) a where
  mut'  = (TName pPreludeIO "Mutable")
stS     = st s
st s a  = RhoTau [] $ ((TCon pos (st')) `TApp` s) `TApp` a where 
  st'   = (TName pPreludeBase "ST")
tcon name   = TCon pos name
eitherTau e = TApp (TApp eitherCon e) where
 eitherCon  = TCon pos (TName pPreludeBase "Either")

sigmaEnv :: Sigma -> Maybe Tau
sigmaEnv sigma = fst <$> (unST $ walkRho sigma.rho)

derive Eq Context
derive Eq Kind
derive Eq Tau
derive Eq Rho
derive Eq Sigma

envToTau :: Env -> Maybe Tau
envToTau (Env _) = Just testWorld
envToTau EnvS    = Just s
envToTau _       = Nothing

instance Arbitrary ResolvedName where
  arbitrary = 
    (\name -> ResolvedName (TName pack name)) <$> arbitrary `suchThat` (not . null) <*> arbitrary

p_ShouldGenerateSimpleSigma :: Property
p_ShouldGenerateSimpleSigma = once $
  let 
    jtype     = JMethod [(JType (ResolvedName unit True) [])] (JType (ResolvedName unit True) []) [] HashMap.empty InstanceMethod
    expected  = ForAll [] (RhoFun [] (ForAll [] unitRho) unitRho)
  in
    toSigma pos (Pure Nothing) jtype == expected

p_ShouldGenerateMultiParamSigma :: Property
p_ShouldGenerateMultiParamSigma = once $
  let 
    jtype    = JMethod [
                 (JType (ResolvedName unit True) [])
               , (JType (ResolvedName unit True) [])
               ] (JType (ResolvedName unit True) []) [] HashMap.empty InstanceMethod
    expected = ForAll [] (RhoFun [] (ForAll [] unitRho) (RhoFun [] (ForAll [] unitRho) unitRho))
  in
    toSigma pos (Pure Nothing) jtype == expected

p_ShouldGenerateSigmaForSTType :: Property
p_ShouldGenerateSigmaForSTType = once $
  let 
    tname     = TName pack "IAmMutable"
    typ       = JType (ResolvedName tname False) []
    bound     = HashMap.empty
    jtype     = JMethod [] typ [] bound InstanceMethod
    res       = toSigma pos EnvS jtype
    resEnv    = sigmaEnv res
  in
    resEnv == Just s && head res.bound == (TVar pos KType "s")

p_ShouldGenerateSigmaForIndexedType :: Property
p_ShouldGenerateSigmaForIndexedType = once $
  let 
    tname  = TName pack "IAmInTestWorld"
    typ    = JType (ResolvedName tname False) []
    bound  = HashMap.empty
    jtype  = JMethod [] typ [] bound InstanceMethod
    res    = toSigma pos (Env stIdx) jtype
    resEnv = sigmaEnv res
  in
    resEnv == Just testWorld

p_ShouldGenerateSigmaForPureIndexedType :: Property
p_ShouldGenerateSigmaForPureIndexedType = once $
  let 
    tname    = TName pack "IAmInTestWorld"
    typ      = JType (ResolvedName tname True) []
    bound    = HashMap.empty
    jtype    = JMethod [] typ [] bound InstanceMethod
    expected = ForAll [] (st testWorld (tcon tname))
    res      = toSigma pos (Env stIdx) jtype
  in
    res == expected

p_ShouldGenerateSigmaForExceptionType :: Property
p_ShouldGenerateSigmaForExceptionType = once $
  let 
    ex        = TName pack "Exception"
    typ       = JType (ResolvedName unit True) []
    exTyp     = JType (ResolvedName ex True) []
    bound     = HashMap.empty
    jtype     = JMethod [] typ [exTyp] bound InstanceMethod
    expected  = ForAll [] (RhoTau [] (eitherTau (tcon ex) (tcon unit)))
    res       = toSigma pos (Pure Nothing) jtype
  in 
    res == expected

p_ShouldGenerateSigmaForExceptionInMutSType :: Property
p_ShouldGenerateSigmaForExceptionInMutSType = once $ 
  let 
    ex        = TName pack "Exception"
    typ       = JType (ResolvedName unit False) []
    exTyp     = JType (ResolvedName ex True) []
    bound     = HashMap.empty
    jtype     = JMethod [] typ [exTyp] bound InstanceMethod
    expected  = ForAll [s] (stS (eitherTau (tcon ex) (mutS $ tcon unit)))
    res       = toSigma pos EnvS jtype
  in
    res == expected

p_ShouldGenerateSigmaForGenericType :: Property
p_ShouldGenerateSigmaForGenericType = once $
  let 
    tname     = TName pack "Parameterized"
    e         = TVar Position.null KType "e"
    param     = JType (ResolvedName tname True) [JVarRef "e"]
    bound     = HashMap.singleton "e" (JVar "e" [])
    returnVal = JType (ResolvedName unit True) []
    jtype     = JMethod [param] returnVal [] bound InstanceMethod
    expected  = ForAll [e] (RhoFun [] (ForAll [] (RhoTau [] (TApp (tcon tname) e))) unitRho)
    res       = toSigma pos (Pure Nothing) jtype
  in
    res == expected

p_ShouldGenerateSigmaForMethodWithBoundedTypeParam :: Property
p_ShouldGenerateSigmaForMethodWithBoundedTypeParam = once $
  let 
    tname     = TName pack "Parameterized"
    bound     = TName pack "Bound"
    e         = TVar Position.null (KGen [TCon Position.null bound]) "e"
    eRef      = TVar Position.null KType "e"
    param     = JType (ResolvedName tname True) [JVarRef "e"]
    typevars  = HashMap.singleton "e" (JVar "e" [(JType (ResolvedName bound True) [])])
    returnVal = JType (ResolvedName unit True) []
    jtype     = JMethod [param] returnVal [] typevars InstanceMethod
    expected  = ForAll [e] (RhoFun [] (ForAll [] (RhoTau [] (TApp (tcon tname) eRef))) unitRho)
    res       = toSigma pos (Pure Nothing) jtype
  in 
    res == expected

p_ShouldGenerateSigmaForMethodWithFBoundedTypeParam :: Property
p_ShouldGenerateSigmaForMethodWithFBoundedTypeParam = once $
  let 
    tname     = TName pack "Parameterized"
    bound     = TName pack "FBound"
    e         = TVar Position.null (KGen [TApp (TCon Position.null bound) eRef]) "e"
    eRef      = TVar Position.null KType "e"
    param     = JType (ResolvedName tname True) [JVarRef "e"]
    typevars  = HashMap.singleton "e" (JVar "e" [JType (ResolvedName bound True) [JVarRef "e"]])
    returnVal = JType (ResolvedName unit True) []
    jtype     = JMethod [param] returnVal [] typevars InstanceMethod
    expected  = ForAll [e] (RhoFun [] (ForAll [] (RhoTau [] (TApp (tcon tname) eRef))) unitRho)
    res       = toSigma pos (Pure Nothing) jtype
  in do
    res == expected

p_ShouldGenerateSigmaForMultiBoundedWildcardType :: Property
p_ShouldGenerateSigmaForMultiBoundedWildcardType = once $
  let 
    tname     = TName pack "Parameterized"
    bound1    = TName pack "Bound1"
    bound2    = TName pack "Bound2"
    wildcard  = TVar Position.null (KGen [TCon Position.null bound1, TCon Position.null bound2]) "<"
    param     = JType (ResolvedName tname True) [JWildcard (Upper [JType (ResolvedName bound1 True) [], JType (ResolvedName bound2 True) []])]
    returnVal = JType (ResolvedName unit  True) []
    jtype     = JMethod [param] returnVal [] HashMap.empty InstanceMethod
    expected  = ForAll [] (RhoFun [] (ForAll [] (RhoTau [] (TApp (tcon tname) wildcard))) unitRho)
    res       = toSigma pos (Pure Nothing) jtype
  in
    res == expected

p_ShouldUnifyMutableSToMethodEnv :: Property
p_ShouldUnifyMutableSToMethodEnv = property $ \(jmethod :: JMethod) -> let
    res       = toSigma pos (Env stIdx) jmethod
    withoutST = map dropST (toTaus res.rho)
    muts      = withoutST >>= dropMut 
  in
    all (\m -> m == testWorld) muts 
  where
    toTaus :: Rho -> [Tau]
    toTaus (RhoFun{sigma, rho}) = toTaus sigma.rho ++ toTaus rho
    toTaus (RhoTau{tau}) = [tau]
    
    dropST :: Tau -> Tau
    dropST (TApp (TApp (TCon {name = TName p "ST"}) st ) ty)
        | p == pPreludeBase = ty
    dropST t = t
    
    dropMut :: Tau -> [Tau]
    dropMut (TApp (TApp (TCon {name = TName p "Mutable"}) idx) r) = idx: dropMut r
    dropMut (TApp a b) = dropMut a ++ dropMut b
    dropMut _ = []
