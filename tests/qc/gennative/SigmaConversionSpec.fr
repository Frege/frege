module tests.qc.gennative.SigmaConversionSpec where

import Test.QuickCheck as Q public

import Compiler.types.QNames(QName(VName))

import Compiler.types.Types(
    Sigma
  , SigmaT(ForAll)
  , RhoT(RhoTau, RhoFun)
  , TauT(TVar, TCon)
  , KindT(KType)
  )
import Compiler.types.Positions
import Compiler.types.QNames
import Compiler.types.Types
import Compiler.types.Packs
import Compiler.natives.types.JTypes
import Compiler.natives.conversion.SigmaConversion(toSigma)
import Data.HashMap



-- some generally used stuff
pos = Position.null
pack = Pack.new "SigmaConversionSpec"
unit = TName pPreludeBase "()"
str  = TApp (TCon pos (TName pPreludeBase "StringJ")) (TCon pos (TName pPreludeBase "Char"))
strRho  = RhoTau [] str
s = TVar Position.null KType "s"
io = TCon Position.null (TName pPreludeBase "RealWorld")
mutIO = mut io 
mutS = mut s
mut s a = TApp (TApp (TCon pos mut') s) a where
  mut' = (TName pPreludeIO "Mutable")
stIO = st io
stS = st s
st s a = RhoTau [] $ ((TCon pos (st')) `TApp` s) `TApp` a
  where st' = (TName pPreludeBase "ST")
tcon name = TCon pos name
strMap = strMap' where 
  strMap' =  TApp (TApp mapCtr str) str
  mapCtr = TCon pos mapName
  mapName = TName (Pack.new "Java.Util") "Map"
tconRho name = RhoTau [] (tcon name)
eitherTau e = TApp (TApp eitherCon e) where
    eitherCon   = TCon pos (TName pPreludeBase "Either")
invalidPersonNameEx = ("examples.ntvdeclstypes.person.InvalidPersonNameException", TCon pos (TName pack "InvalidPersonNameException"))
ex = ("java.lang.Exception", TCon pos (TName pPreludeIO "Exception"))
strQName  = (TName (Pack.new "Java.lang") "String")

derive Eq Context
derive Eq Kind
derive Eq Tau
derive Eq Rho
derive Eq Sigma

derive Show Context
derive Show MetaTv
derive Show Tau
derive Show Rho
derive Show Sigma

p_ShouldGenerateSimpleSigma :: Property
p_ShouldGenerateSimpleSigma = once $
  let 
    jtype     = JMethod [(JType (QualifiedName strQName Pure) [])] (JType (QualifiedName strQName Pure) []) [] HashMap.empty

    expected = ForAll [] (RhoFun [] (ForAll [] strRho) strRho)
  in
    toSigma pos jtype == expected

p_ShouldGenerateSigmaForGenericType :: Property
p_ShouldGenerateSigmaForGenericType = once $
  let 
    tname     = TName pack "ArrayList"
    e         = TVar Position.null KType "e"
    param     = JType (QualifiedName tname EnvS) [JVarRef "e"]
    bound     = HashMap.singleton "e" (JVar "e" [])
    returnVal = JType (QualifiedName unit Pure) []
    jtype     = JMethod [param] returnVal [] bound
    expected  = ForAll [s, e] (RhoFun [] (ForAll [] (RhoTau [] (mutS (TApp (tcon tname) e)))) (stS (tcon unit)))
    res = toSigma pos jtype
  in
    res == expected

p_ShouldGenerateSigmaForBoundedGenericType :: Property
p_ShouldGenerateSigmaForBoundedGenericType = once $
  let 
    tname     = TName pack "ArrayList"
    bound     = TName pack "Number"
    e         = TVar Position.null (KGen [TCon Position.null bound]) "e"
    eRef      = TVar Position.null KType "e"
    param     = JType (QualifiedName tname EnvS) [JVarRef "e"]
    typevars  = HashMap.singleton "e" (JVar "e" [(JType (QualifiedName bound Pure) [])])
    returnVal = JType (QualifiedName unit Pure) []
    jtype     = JMethod [param] returnVal [] typevars
    expected  = ForAll [s, e] (RhoFun [] (ForAll [] (RhoTau [] (mutS (TApp (tcon tname) eRef)))) (stS (tcon unit)))
    res = toSigma pos jtype
  in 
    res == expected

p_ShouldGenerateSigmaForMultiBoundedGenericType :: Property
p_ShouldGenerateSigmaForMultiBoundedGenericType = once $
  let 
    tname     = TName pack "ArrayList"
    bound1    = TName pack "Number"
    bound2    = TName pack "Comparable"
    e         = TVar Position.null (KGen [TCon Position.null bound1, TCon Position.null bound2]) "e"
    eRef      = TVar Position.null KType "e"
    param     = JType (QualifiedName tname EnvS) [JVarRef "e"]
    typevars  = HashMap.singleton "e" (JVar "e" [JType (QualifiedName bound1 Pure) [],JType (QualifiedName bound2 Pure) []])
    returnVal = JType (QualifiedName unit Pure) []
    jtype     = JMethod [param] returnVal [] typevars
    expected  = ForAll [s, e] (RhoFun [] (ForAll [] (RhoTau [] (mutS (TApp (tcon tname) eRef)))) (stS (tcon unit)))
    res       = toSigma pos jtype
  in do
    res == expected

p_ShouldGenerateSigmaForWildcardType :: Property
p_ShouldGenerateSigmaForWildcardType = once $
  let 
    tname     = TName pack "ArrayList"
    bound1    = TName pack "Number"
    bound2    = TName pack "Comparable"
    wildcard  = TVar Position.null (KGen [TCon Position.null bound1, TCon Position.null bound2]) "<"
    param     = JType (QualifiedName tname EnvS) [JWildcard (Upper [JType (QualifiedName bound1 Pure) [], JType (QualifiedName bound2 Pure) []])]
    returnVal = JType (QualifiedName unit Pure) []
    jtype     = JMethod [param] returnVal [] HashMap.empty
    expected  = ForAll [s] (RhoFun [] (ForAll [] (RhoTau [] (mutS (TApp (tcon tname) wildcard)))) (stS (tcon unit)))
    res = toSigma pos jtype
  in
    res == expected
